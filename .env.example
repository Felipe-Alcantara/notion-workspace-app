# Token de integração do Notion.
# Crie uma integração em https://www.notion.so/my-integrations,
# compartilhe o database/página alvo com ela e cole o token aqui.
# O token deve começar com "ntn_".
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do database de tarefas padrão (opcional — pode ser passado por chamada).
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do database que recebe páginas de projetos importados do GitHub.
# NOTION_PROJECTS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token do GitHub (opcional para públicos; necessário para privados).
# Prefira token fine-grained com acesso somente de leitura aos repositórios usados.
# GITHUB_TOKEN=

# --- Servidor Django (opcional — só necessário se usar server/) ---

# Chave secreta do Django. OBRIGATÓRIA em produção (DEBUG desligado).
# Em modo debug, uma chave de desenvolvimento é usada automaticamente.
# Gere uma com: python -c "import secrets; print(secrets.token_urlsafe(50))"
# DJANGO_SECRET_KEY=

# Liga o modo debug do Django (1/true/yes/on). Padrão: desligado.
# DJANGO_DEBUG=1

# Hosts permitidos, separados por vírgula. Padrão: * em debug, localhost fora.
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Caminho do SQLite operacional (jobs, locks). Padrão: operacional.sqlite3 na raiz.
# OPERATIONAL_DB_PATH=operacional.sqlite3
